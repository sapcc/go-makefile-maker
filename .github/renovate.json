{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "default:pinDigestsDisabled",
    "mergeConfidence:all-badges",
    "docker:enableMajor",
    "customManagers:dockerfileVersions"
  ],
  "assignees": [
    "SuperSandro2000"
  ],
  "commitMessageAction": "Renovate: Update",
  "constraints": {
    "go": "1.26"
  },
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "/.*/"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "External dependencies"
    },
    {
      "matchPackageNames": [
        "/^github\\.com\\/sapcc\\/.*/"
      ],
      "automerge": true,
      "groupName": "github.com/sapcc"
    },
    {
      "matchPackageNames": [
        "go",
        "golang",
        "actions/go-versions"
      ],
      "groupName": "golang",
      "separateMinorPatch": true
    },
    {
      "matchPackageNames": [
        "go",
        "golang",
        "actions/go-versions"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "dependencyDashboardApproval": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "alpine",
      "managerFilePatterns": [
        "/^internal\\/core\\/constants\\.go$/"
      ],
      "matchStrings": [
        "DefaultAlpineImage\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go",
      "managerFilePatterns": [
        "/^internal\\/core\\/constants\\.go$/"
      ],
      "matchStrings": [
        "DefaultGoVersion\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "postgres",
      "managerFilePatterns": [
        "/^internal\\/core\\/constants\\.go$/"
      ],
      "matchStrings": [
        "DefaultPostgresVersion\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "linkerd/linkerd-await",
      "extractVersionTemplate": "^release/v(?<version>.*)$",
      "managerFilePatterns": [
        "/^internal\\/core\\/constants\\.go$/"
      ],
      "matchStrings": [
        "DefaultLinkerdAwaitVersion\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ],
  "prHourlyLimit": 0,
  "schedule": [
    "before 8am on Friday"
  ],
  "semanticCommits": "disabled"
}
